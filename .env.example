# ─── Google Gemini ───────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── ElevenLabs ──────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here          # e.g. "21m00Tcm4TlvDq8ikWAM" (Rachel)

# ─── MongoDB Atlas ───────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=auraguard
MONGODB_COLLECTION=events

# ─── Snowflake ───────────────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=AURAGUARD
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# ─── Patient Config ──────────────────────────────────────────────────────────
PATIENT_NAME=Ismail
PATIENT_ID=patient_001

# ─── Audio Output ─────────────────────────────────────────────────────────────
# Set to the system audio device name for the Meta Smart Glasses speaker.
# Run `python -c "import pygame; pygame.mixer.init(); print(pygame.mixer.get_init())"` 
# or check system sound settings to find the exact device name.
GLASSES_AUDIO_DEVICE=Meta Smart Glasses

# ─── Service URLs ────────────────────────────────────────────────────────────
VISION_HOST=localhost
VISION_PORT=5000
BRAIN_HOST=localhost
BRAIN_PORT=8000
DASHBOARD_PORT=8501
